{
  "name": "toizero-remote-panel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"blue,green\" \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=frontend"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dompurify": "3.4.0",
    "follow-redirects": "1.16.0",
    "serialize-javascript": "7.0.5"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "vite": "^8.0.8"
  },
  "overrides": {
    "dompurify": "3.4.0",
    "follow-redirects": "1.16.0",
    "serialize-javascript": "7.0.5"
  }
}
