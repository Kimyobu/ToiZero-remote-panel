{
  "name": "toizero-ext",
  "displayName": "ToiZero Panel",
  "description": "VSCode Extension for ToiZero - synchronize scores and submit solutions locally.",
  "version": "0.0.1",
  "publisher": "kimyobu",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimyobu/toizero"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "toizero.submitActive",
        "title": "ToiZero: Submit Solution"
      },
      {
        "command": "toizero.login",
        "title": "ToiZero: Sync Login"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "socket.io-client": "^4.8.3"
  },
  "overrides": {
    "dompurify": "3.4.0",
    "follow-redirects": "1.16.0",
    "serialize-javascript": "7.0.5"
  }
}
